
<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
    <div class="col-8 offset-2">

        <h3>Edit Your  Listing</h3>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">

            <!-- Title -->
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input
                    id="title"
                    name="listing[title]"
                    type="text"
                    value="<%= listing.title %>"
                    class="form-control"
                    required
                >
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea
                    id="description"
                    name="listing[Description]"
                    class="form-control"
                    rows="4"
                ><%= listing.Description %></textarea>
            </div>

            <!-- Image URL -->
            <div class="mb-3">
                <label for="image" class="form-label">Image Link</label>
                <input
                    id="image"
                    name="listing[image]"
                    type="text"
                    value="<%= listing.image %>"
                    class="form-control"
                >
            </div>

            <div class="row">
                <!-- Price -->
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input
                        id="price"
                        name="listing[price]"
                        type="number"
                        value="<%= listing.price %>"
                        class="form-control"
                    >
                </div>

                <!-- Country -->
                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input
                        id="country"
                        name="listing[country]"
                        type="text"
                        value="<%= listing.country %>"
                        class="form-control"
                    >
                </div>
            </div>

            <!-- Location -->
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input
                    id="location"
                    name="listing[location]"
                    type="text"
                    value="<%= listing.location %>"
                    class="form-control"
                >
            </div>

            <button type="submit" class="btn btn-dark edit-btn mt-3">
                Update Listing
            </button>

        </form>

    </div>
</div>

