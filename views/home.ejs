    <div class="row text-center">


        <div class="col-md-2 col-6 mb-4">

            <i class="fa-solid fa-umbrella-beach fs-1 text-danger"></i>

            <p class="mt-3 fw-bold">
                Beach Trips
            </p>

        </div>



        <div class="col-md-2 col-6 mb-4">

            <i class="fa-solid fa-mountain-sun fs-1 text-success"></i>

            <p class="mt-3 fw-bold">
                Mountains
            </p>

        </div>




        <div class="col-md-2 col-6 mb-4">

            <i class="fa-solid fa-hotel fs-1 text-primary"></i>

            <p class="mt-3 fw-bold">
                Luxury Stays
            </p>

        </div>




        <div class="col-md-2 col-6 mb-4">

            <i class="fa-solid fa-camera fs-1 text-warning"></i>

            <p class="mt-3 fw-bold">
