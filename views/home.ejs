        </div>




        <div class="col-md-2 col-6 mb-4">

            <i class="fa-solid fa-tree fs-1 text-success"></i>

            <p class="mt-3 fw-bold">
                Nature
            </p>

        </div>




        <div class="col-md-2 col-6 mb-4">

            <i class="fa-solid fa-route fs-1 text-danger"></i>

            <p class="mt-3 fw-bold">
                Adventure
            </p>

        </div>



    </div>

</section>





<!-- Why Choose Us -->

<section class="bg-light py-5">

<div class="container">


<h2 class="text-center fw-bold mb-5">
Why Choose ExploreHub?
</h2>



<div class="row text-center">


<div class="col-md-4">

<i class="fa-solid fa-location-dot fs-1 text-danger"></i>

<h4 class="mt-3">
Amazing Destinations
</h4>

<p>
Find beautiful places around the world.
</p>

</div>




<div class="col-md-4">

<i class="fa-solid fa-house-circle-check fs-1 text-success"></i>

<h4 class="mt-3">
Verified Stays
</h4>

